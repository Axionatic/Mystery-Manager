  "group_qty_exponent": 1.0,
  "desirability_penalty_multiplier": 1.0,
  "desirability_shrinkage_prior": 1,
  "diversity_penalty_multiplier": 1.0,
  "fairness_penalty_multiplier": 1.0,
  "pref_violation_penalty": 1.0,
  "max_composite_score": 100.0,

  "pack_price_tolerance_cents": 5,
  "diversity_fallback_score": 0.5,

  "fungible_neutral_score": 0.5,
  "fungible_new_group_bonus": 1.0,

  "topup_max_passes": 50,

# DB credentials (used for both direct and SSH tunnel connections).
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Business pricing (cents). Required for allocation.
BOX_PRICE_SMALL=0
BOX_PRICE_MEDIUM=0
BOX_PRICE_LARGE=0
BOX_TARGET_PCT=100             # Target box value as % of price (e.g. 100 = 100%)
CHARITY_NAME=Charity           # Charity recipient name (used as default header label)
CHARITY_BASE_PERCENT=0.0       # Base charity allocation as fraction of total overage value
CHARITY_GIVING_MULTIPLIER=2.0  # Multiplier on giving items for charity target

# SSH tunnel (optional). Set SSH_ENABLED=true and choose one auth method.
SSH_ENABLED=false
# SSH_HOST=192.0.2.1
# SSH_USER=deploy
#
# Key-based auth (recommended):
# SSH_KEY_PATH=~/.ssh/id_rsa
# SSH_KEY_PASSPHRASE=          # optional
#
# Password-based auth:
# SSH_PASSWORD=your_ssh_password
